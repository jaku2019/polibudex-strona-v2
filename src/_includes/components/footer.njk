<footer class="footer" role="contentinfo">
  <div class="footer-inner container">
    <div class="footer-brand">
      <img src="/assets/images/logo.svg" alt="{{ site.nazwa }} logo" width="28" height="28">
      <span>{{ site.nazwa }}</span>
      <p>{{ site.opis }}</p>
    </div>

    <nav class="footer-nav" aria-label="Linki stopki">
      <h3>Nawigacja</h3>
      <ul role="list">
        {% for item in navigation %}
        <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="footer-contact">
      <h3>Kontakt</h3>
      <p>
        <a href="mailto:{{ site.kontakt.email }}" aria-label="Wyślij email">
          {{ site.kontakt.email }}
        </a>
      </p>
      <p>{{ site.kontakt.adres }}</p>
    </div>

    <div class="footer-social">
      <h3>Social media</h3>
      <div class="social-links" role="list">
        {% if site.social.facebook %}
        <a href="{{ site.social.facebook }}" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook Polibudex" role="listitem">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        {% endif %}
        {% if site.social.instagram %}
        <a href="{{ site.social.instagram }}" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram Polibudex" role="listitem">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        {% endif %}
        {% if site.social.github %}
        <a href="{{ site.social.github }}" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub Polibudex" role="listitem">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {{ site.nazwa }} 2026. Wszelkie prawa zastrzeżone.</p>
  </div>
</footer>
